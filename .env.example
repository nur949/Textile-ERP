# Set this to your PostgreSQL database URL, such as Neon or another hosted Postgres instance.
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Set an application secret for JWT signing.
JWT_SECRET=your_jwt_secret

# Optional frontend origin for CORS. When deploying to Vercel, set this to your Vercel URL.
FRONTEND_ORIGIN=https://textile-erp-okr1.vercel.app/
